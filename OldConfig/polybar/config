include-file = ~/.config/polybar/modules.ini
include-file = ~/.config/polybar/colors.ini

[bar/example]
background = #1A374D
background-alt = #1A374D
foreground = #C5C8C6
primary = #F0C674
secondary = #9088D4
alert = #A54242
disabled = #707880

border-size = 6
border-color = #00000000
margin-bottom = 0

monitor = ${env:MONITOR:}
width = 100%
height = 30
radius = 12
fixed-center = true
padding-left = 7
padding-right = 5
margin-top = 5
module-margin-left = 2
module-margin-right = 2
font-0 = Fira Code:style=Regular:size=12;4
font-1 = Hack Nerd Font:size=15;2
font-2 = Hack Nerd Font:size=15;2
font-3 = FiraCode Nerd Font Mono:style=Regular:size=18;4
font-4 = Hack Nerd Font:size=18;2
font-5 = Hack Nerd Font:size=20;2

wm-restack = bspwm
scroll-up = #bspwm.prev
scroll-down = #bspwm.next
cursor-click = pointer
cursor-scroll = pointer
enable-ipc = true

;;;;;; Module Positioning
modules-left = launcher bspwm
modules-center = xwindow
modules-right = date

[settings]
screenchange-reload = true
;compositing-background = xor
;compositing-background = screen
;compositing-foreground = source
;compositing-border = over
;pseudo-transparency = false [global/wm] margin-top = 5 margin-bottom = 5 vim:set ft=dosini:

